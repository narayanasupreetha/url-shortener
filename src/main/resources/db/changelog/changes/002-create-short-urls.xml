<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="002-create-short-urls" author="admin">

        <createTable tableName="short_urls">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>

            <column name="short_code" type="VARCHAR(20)">
                <constraints nullable="false" unique="true"/>
            </column>

            <column name="original_url" type="TEXT">
                <constraints nullable="false"/>
            </column>

            <column name="is_active" type="BOOLEAN" defaultValueBoolean="true"/>

            <column name="expires_at" type="TIMESTAMP"/>

            <column name="created_at" type="TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="short_urls"
                baseColumnNames="user_id"
                constraintName="fk_short_urls_user"
                referencedTableName="users"
                referencedColumnNames="id"/>

        <createIndex indexName="idx_short_code" tableName="short_urls">
            <column name="short_code"/>
        </createIndex>
        
    </changeSet>

</databaseChangeLog>