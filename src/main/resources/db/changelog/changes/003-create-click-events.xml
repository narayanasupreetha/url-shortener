<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="003-create-click-events" author="admin">

        <createTable tableName="url_click_events">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="short_url_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>

            <column name="clicked_at" type="TIMESTAMP"/>

            <column name="ip_address" type="VARCHAR(100)"/>
            <column name="user_agent" type="TEXT"/>
            <column name="referrer" type="TEXT"/>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="url_click_events"
                baseColumnNames="short_url_id"
                constraintName="fk_click_short_url"
                referencedTableName="short_urls"
                referencedColumnNames="id"/>

        <createIndex indexName="idx_clicked_at" tableName="url_click_events">
            <column name="clicked_at"/>
        </createIndex>

    </changeSet>

</databaseChangeLog>